# Now route all the features into the recorder, changing their
# feature type to the transformer name so that they view nicely
DEFAULT_MACRO VISUALIZER_FEATURE_FILE $(WORKSPACE_TEMP_DIR)/$(SAFE_FFS_NAME).ffs
DEFAULT_MACRO VISUALIZER_CREATE_SPATIAL_INDEX NO
# [PR#45549] The Data Inspector will limit the maximum number of features
# it reads on WIN32, so we will correspondingly limit the number of
# features we record here using the MAX_FEATURES_TO_RECORD directive.
FACTORY_DEF {$(ENABLE_RECORDING)} RecorderFactory    FACTORY_NAME { _a_Failed_Recorder }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT FEATURE_TYPE __viewme__       _wb_termination_feature Yes       @FeatureType(TERMINATOR_@Value(_wb_termination_xformer))    INPUT FEATURE_TYPE __viewme__       @FeatureType(@Value(__inspector_feature_type_attr__))       @RemoveAttributes(__inspector_feature_type_attr__)    FEATURE_FILE { "$(VISUALIZER_FEATURE_FILE)" }    STORE_SCANNED_SCHEMA YES    NORMALIZE_LIST_ATTRIBUTES_ON_SCHEMA YES    CREATE_SPATIAL_INDEX { "$(VISUALIZER_CREATE_SPATIAL_INDEX)" }    INSPECTOR { "$(VISUALIZER_CREATE_SPATIAL_INDEX)" }    FSC_SCHEMA { fme_feature_type,varchar<openparen>50<closeparen>,name,buffer,aerialway,buffer,addr:housenumber,buffer,addr:street,buffer,admin_level,buffer,aeroway,buffer,amenity,buffer,barrier,buffer,boundary,buffer,building,buffer,bus,buffer,craft,buffer,electrified,buffer,emergency,buffer,fire_hydrant:diameter,buffer,fire_hydrant:position,buffer,fire_hydrant:type,buffer,gauge,buffer,geological,buffer,highway,buffer,historic,buffer,information,buffer,landuse,buffer,leisure,buffer,man_made,buffer,military,buffer,natural,buffer,network,buffer,office,buffer,place,buffer,power,buffer,public_transport,buffer,railway,buffer,ref,buffer,route,buffer,shop,buffer,source,buffer,sport,buffer,tourism,buffer,type,buffer,unfiltered,buffer,unknown,buffer,waterway,buffer,_part_number,uint64,_geometry_label,buffer,id,char<openparen>36<closeparen> }    MODE RECORD    STORE_SCANNED_METADATA    RECORD_DIRECTLY_TO_DISK YES    MAX_FEATURES_TO_RECORD WIN32 2000000    LARGE_GEOMETRY_DATA_STORAGE { $(_a_Failed_46f2d833_7dca_4dd6_9fb6_3b0a29da1a1a0_LARGE_GEOMETRY_DATA_STORAGE) }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { _a_Failed_Nuker }    INPUT FEATURE_TYPE __viewme__
