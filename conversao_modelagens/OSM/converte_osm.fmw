# source of the OSM PBF Files.
# The user input is stored in a macro, which is then used to define
# the dataset to be read.
# The dataset this mapping file was generated from was:
#! END_SOURCE_HEADER
#! START_WB_HEADER
DEFAULT_MACRO SourceDataset
INCLUDE [ if {{$(SourceDataset)} != ""} {                        \
 puts {DEFAULT_MACRO SourceDataset_OSMPBF_1 $(SourceDataset)}     \
 } ]
#! END_WB_HEADER
#! START_SOURCE_HEADER OSMPBF OSMPBF_1
DEFAULT_MACRO SourceDataset_OSMPBF_1 $(SourceDataset_OSMPBF)
GUI MULTIFILE SourceDataset_OSMPBF_1 OSMPBF_Files(*.osm.pbf)|*.osm.pbf|All_Files(*)|* Source OSM PBF File(s):
DEFAULT_MACRO OSMPBF_IN_COMMUNITY_FEATURE_TYPES_OSMPBF_1 MAPPED
OSMPBF_1_COMMUNITY_FEATURE_TYPES "$(OSMPBF_IN_COMMUNITY_FEATURE_TYPES_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_USER_CONFIG_OSMPBF_1 NO
OSMPBF_1_USER_CONFIG "$(OSMPBF_IN_USER_CONFIG_OSMPBF_1)"
GUI ACTIVEDISCLOSUREGROUP OSMPBF_IN_USER_CONFIG_OSMPBF_1 FME_DISCLOSURE_CLOSED%OSMPBF_IN_USER_CONFIG_PATH_OSMPBF_1 User Defined OSM Map Features
DEFAULT_MACRO OSMPBF_IN_USER_CONFIG_PATH_OSMPBF_1 <Unused>
GUI FILENAME_ENCODED_MUSTEXIST OSMPBF_IN_USER_CONFIG_PATH_OSMPBF_1 XML_Files(*.xml)|*.xml|All_Files(*)|* Map Features Config File:
OSMPBF_1_USER_CONFIG_PATH "$(OSMPBF_IN_USER_CONFIG_PATH_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_CATEGORIES_QUERY_OSMPBF_1 
OSMPBF_1_CATEGORIES_QUERY "$(OSMPBF_IN_CATEGORIES_QUERY_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_HANDLE_MULTI_OSMPBF_1 SELECT_FIRST
OSMPBF_1_HANDLE_MULTI "$(OSMPBF_IN_HANDLE_MULTI_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_EXPOSE_ATTRS_GROUP_OSMPBF_1 
OSMPBF_1_EXPOSE_ATTRS_GROUP "$(OSMPBF_IN_EXPOSE_ATTRS_GROUP_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_SPATIAL_GROUP_OSMPBF_1 
GUI OPTIONAL DISCLOSUREGROUP OSMPBF_IN_SPATIAL_GROUP_OSMPBF_1 OSMPBF_IN_COORDINATE_SYSTEM_OSMPBF_1%OSMPBF_IN_USE_SEARCH_ENVELOPE_OSMPBF_1 Spatial
DEFAULT_MACRO OSMPBF_IN_COORDINATE_SYSTEM_OSMPBF_1 
OSMPBF_1_COORDINATE_SYSTEM "$(OSMPBF_IN_COORDINATE_SYSTEM_OSMPBF_1)"
GUI OPTIONAL COORDSYS OSMPBF_IN_COORDINATE_SYSTEM_OSMPBF_1 Coordinate System:
# Include this file in source setting section to add external search envelope processing
# Zero as a default means we don't do any search -- this makes workbench happier
DEFAULT_MACRO OSMPBF_IN_USE_SEARCH_ENVELOPE_OSMPBF_1 NO
OSMPBF_1_USE_SEARCH_ENVELOPE "$(OSMPBF_IN_USE_SEARCH_ENVELOPE_OSMPBF_1)"
GUI ACTIVEDISCLOSUREGROUP OSMPBF_IN_USE_SEARCH_ENVELOPE_OSMPBF_1 OSMPBF_IN_SEARCH_ENVELOPE_MINX_OSMPBF_1%OSMPBF_IN_SEARCH_ENVELOPE_MINY_OSMPBF_1%OSMPBF_IN_SEARCH_ENVELOPE_MAXX_OSMPBF_1%OSMPBF_IN_SEARCH_ENVELOPE_MAXY_OSMPBF_1%OSMPBF_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_OSMPBF_1%OSMPBF_IN_CLIP_TO_ENVELOPE_OSMPBF_1%OSMPBF_IN_SEARCH_METHOD%OSMPBF_IN_SEARCH_METHOD_FILTER%OSMPBF_IN_SEARCH_ORDER%OSMPBF_IN_SEARCH_FEATURE%OSMPBF_IN_DUMMY_SEARCH_ENVELOPE_PARAMETER Use Search Envelope
# ===========================================================================
GUI LOOKUP OSMPBF_IN_SEARCH_ENVELOPE_MINX_OSMPBF_1 <Unused>,0 
DEFAULT_MACRO OSMPBF_IN_SEARCH_ENVELOPE_MINX_OSMPBF_1 0
OSMPBF_1_SEARCH_ENVELOPE "$(OSMPBF_IN_SEARCH_ENVELOPE_MINX_OSMPBF_1)"
GUI OPTIONAL FLOAT OSMPBF_IN_SEARCH_ENVELOPE_MINX_OSMPBF_1 Minimum X:
# ===========================================================================
GUI LOOKUP OSMPBF_IN_SEARCH_ENVELOPE_MINY_OSMPBF_1 <Unused>,0 
DEFAULT_MACRO OSMPBF_IN_SEARCH_ENVELOPE_MINY_OSMPBF_1 0
OSMPBF_1_SEARCH_ENVELOPE "$(OSMPBF_IN_SEARCH_ENVELOPE_MINY_OSMPBF_1)"
GUI OPTIONAL FLOAT OSMPBF_IN_SEARCH_ENVELOPE_MINY_OSMPBF_1 Minimum Y:
# ===========================================================================
GUI LOOKUP OSMPBF_IN_SEARCH_ENVELOPE_MAXX_OSMPBF_1 <Unused>,0 
DEFAULT_MACRO OSMPBF_IN_SEARCH_ENVELOPE_MAXX_OSMPBF_1 0
OSMPBF_1_SEARCH_ENVELOPE "$(OSMPBF_IN_SEARCH_ENVELOPE_MAXX_OSMPBF_1)"
GUI OPTIONAL FLOAT OSMPBF_IN_SEARCH_ENVELOPE_MAXX_OSMPBF_1 Maximum X:
# ===========================================================================
GUI LOOKUP OSMPBF_IN_SEARCH_ENVELOPE_MAXY_OSMPBF_1 <Unused>,0 
DEFAULT_MACRO OSMPBF_IN_SEARCH_ENVELOPE_MAXY_OSMPBF_1 0
OSMPBF_1_SEARCH_ENVELOPE "$(OSMPBF_IN_SEARCH_ENVELOPE_MAXY_OSMPBF_1)"
GUI OPTIONAL FLOAT OSMPBF_IN_SEARCH_ENVELOPE_MAXY_OSMPBF_1 Maximum Y:
# ===========================================================================
GUI LOOKUP OSMPBF_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_OSMPBF_1 <Unused>, 
DEFAULT_MACRO OSMPBF_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_OSMPBF_1 
OSMPBF_1_SEARCH_ENVELOPE "$(OSMPBF_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_OSMPBF_1)"
GUI OPTIONAL COORDSYS OSMPBF_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_OSMPBF_1 Search Envelope Coordinate System:
# ===========================================================================
# BUG18999: We now have a soft clip to fall back on like native spatial index
# thus we are reintroducing the clip to envelop as an option for users.
# Defualt to soft clip as per the existing database readers we are emulating
GUI LOOKUP OSMPBF_IN_CLIP_TO_ENVELOPE_OSMPBF_1 <Unused>,NO 
DEFAULT_MACRO OSMPBF_IN_CLIP_TO_ENVELOPE_OSMPBF_1 NO
OSMPBF_1_CLIP_TO_ENVELOPE "$(OSMPBF_IN_CLIP_TO_ENVELOPE_OSMPBF_1)"
GUI OPTIONAL CHECKBOX OSMPBF_IN_CLIP_TO_ENVELOPE_OSMPBF_1 YES%NO Clip to Search Envelope
DEFAULT_MACRO OSMPBF_IN_ADVANCED_GROUP_OSMPBF_1 
GUI OPTIONAL DISCLOSUREGROUP OSMPBF_IN_ADVANCED_GROUP_OSMPBF_1 OSMPBF_IN_CACHE_SIZE_IN_MB_OSMPBF_1%OSMPBF_IN_USE_FAST_NODE_INDEX_OSMPBF_1 Advanced
DEFAULT_MACRO OSMPBF_IN_CACHE_SIZE_IN_MB_OSMPBF_1 
OSMPBF_1_CACHE_SIZE_IN_MB "$(OSMPBF_IN_CACHE_SIZE_IN_MB_OSMPBF_1)"
GUI OPTIONAL INTEGER OSMPBF_IN_CACHE_SIZE_IN_MB_OSMPBF_1 Cache Size in MB:
DEFAULT_MACRO OSMPBF_IN_USE_FAST_NODE_INDEX_OSMPBF_1 Yes
OSMPBF_1_USE_FAST_NODE_INDEX "$(OSMPBF_IN_USE_FAST_NODE_INDEX_OSMPBF_1)"
GUI CHOICE OSMPBF_IN_USE_FAST_NODE_INDEX_OSMPBF_1 Yes%No Use Fast Index:
DEFAULT_MACRO OSMPBF_IN_READ_BOOLEANS_AS_YES_NO_OSMPBF_1 YES
OSMPBF_1_READ_BOOLEANS_AS_YES_NO "$(OSMPBF_IN_READ_BOOLEANS_AS_YES_NO_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_READ_NULLS_OSMPBF_1 YES
OSMPBF_1_READ_NULLS "$(OSMPBF_IN_READ_NULLS_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS_OSMPBF_1 Yes
OSMPBF_1_QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS "$(OSMPBF_IN_QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS_OSMPBF_1)"
DEFAULT_MACRO OSMPBF_IN_ENCODE_FEATURE_TYPE_AND_ATTR_NAMES_OSMPBF_1 YES
OSMPBF_1_ENCODE_FEATURE_TYPE_AND_ATTR_NAMES "$(OSMPBF_IN_ENCODE_FEATURE_TYPE_AND_ATTR_NAMES_OSMPBF_1)"
# ===========================================================================
DEFAULT_MACRO OSMPBF_IN_NETWORK_AUTHENTICATION_OSMPBF_1 
OSMPBF_1_NETWORK_AUTHENTICATION "$(OSMPBF_IN_NETWORK_AUTHENTICATION_OSMPBF_1)"
GUI OPTIONAL AUTHENTICATOR OSMPBF_IN_NETWORK_AUTHENTICATION_OSMPBF_1 CONTAINER%GROUP%CONTAINER_TITLE%"Network Authentication"%PROMPT_TYPE%NETWORK Network Authentication
# ============================================================================
DEFAULT_MACRO OSMPBF_IN_ATTRIBUTE_READING_OSMPBF_1 DEFLINE
OSMPBF_1_ATTRIBUTE_READING "$(OSMPBF_IN_ATTRIBUTE_READING_OSMPBF_1)"
# ============================================================================
OSMPBF_1_GENERATE_FME_BUILD_NUM 25827
OSMPBF_1_DATASET "$(SourceDataset_OSMPBF_1)"
