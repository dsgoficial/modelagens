DEFAULT_MACRO FME_LAUNCH_VIEWER_APP NO
INCLUDE [    set safeName "[regsub -all {[^a-zA-Z0-9]} {_a_Failed} _]_[expr round(rand() * 1000000)]_[clock clicks  -milliseconds]";    puts "MACRO SAFE_FFS_NAME $safeName"; ]
INCLUDE [    if {{NoReduction} == {NoReduction} &&        {NO_THINNING} == {NO_THINNING}} {       puts "MACRO _a_Failed_46f2d833_7dca_4dd6_9fb6_3b0a29da1a1a0_LARGE_GEOMETRY_DATA_STORAGE REFERENCE";    } else {       puts "MACRO _a_Failed_46f2d833_7dca_4dd6_9fb6_3b0a29da1a1a0_LARGE_GEOMETRY_DATA_STORAGE FULL";    }; ]
INCLUDE [    if {{$(FME_LAUNCH_VIEWER_APP)} != {NO}} {       puts "MACRO ENABLE_RECORDING *";    } else {       puts "MACRO ENABLE_RECORDING _NOT_THIS_TIME_";    }; ]
