FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE POSTGIS POSTGIS_2::edgv.aux_moldura_100k_a multi_reader_keyword,$(DATASET_KEYWORD_POSTGIS_2) TO FME_GENERIC ::edgv.aux_moldura_100k_a ALIAS_GEOMETRY    ROUTE OSMPBF OSMPBF_1::aerialway multi_reader_keyword,$(DATASET_KEYWORD_OSMPBF_1) TO FME_GENERIC ::aerialway ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
POSTGIS_2_MERGE_DEF POSTGIS_2::edgv.aux_moldura_100k_a GLOB * DEFLINE postgis_sql_where_clause,,postgis_sql_statement,
OSMPBF_1_MERGE_DEF OSMPBF_1::aerialway GLOB * DEFLINE osmpbf_type,osmpbf_area<space>osmpbf_no_geom<space>osmpbf_node<space>osmpbf_relation<space>osmpbf_way,fme_attribute_reading,all,name,string,aerialway,string,addr:housenumber,string,addr:street,string,admin_level,string,aeroway,string,amenity,string,barrier,string,boundary,string,building,string,bus,string,craft,string,electrified,string,emergency,string,fire_hydrant:diameter,string,fire_hydrant:position,string,fire_hydrant:type,string,gauge,string,geological,string,highway,string,historic,string,information,string,landuse,string,leisure,string,man_made,string,military,string,natural,string,network,string,office,string,place,string,power,string,public_transport,string,railway,string,ref,string,route,string,shop,string,source,string,sport,string,tourism,string,type,string,unfiltered,string,unknown,string,waterway,string
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "edgv.aux_moldura_100k_a_POSTGIS_2 Splitter"    INPUT FEATURE_TYPE edgv.aux_moldura_100k_a
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "aerialway_OSMPBF_1 Splitter"    INPUT FEATURE_TYPE aerialway    OUTPUT FEATURE_TYPE aerialway_OSMPBF_1
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
FACTORY_DEF {*} DeaggregateFactory    FACTORY_NAME { Deaggregator }    INPUT  FEATURE_TYPE aerialway_OSMPBF_1    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    RECURSIVE { No }    SPLIT_COMPOSITES { No }    INSTANTIATE_GEOMETRY_INSTANCES_NEW { No }    SET_FME_TYPE Yes    PART_NUMBER_FIELD { _part_number }    GEOMETRY_LABEL_FIELD { _geometry_label }    OUTPUT { POINT FEATURE_TYPE Deaggregator_DEAGGREGATED         }    OUTPUT { LINE FEATURE_TYPE Deaggregator_DEAGGREGATED         }    OUTPUT { POLYGON FEATURE_TYPE Deaggregator_DEAGGREGATED         }    OUTPUT { DONUT FEATURE_TYPE Deaggregator_DEAGGREGATED         }    OUTPUT { AGGREGATE FEATURE_TYPE Deaggregator_DEAGGREGATED         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} GeometryFilterFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { GeometryFilter }    INPUT  FEATURE_TYPE Deaggregator_DEAGGREGATED    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    FILTER_TYPES { Point,Area,Curve }    INSTANCES { INSTANTIATE }    BREAK_AGG { Yes }    OUTPUT { <UNFILTERED> FEATURE_TYPE GeometryFilter_<UNFILTERED>  }    OUTPUT { Point FEATURE_TYPE GeometryFilter_Point  }    OUTPUT { Area FEATURE_TYPE GeometryFilter_Area  }    OUTPUT { Curve FEATURE_TYPE GeometryFilter_Curve  }
FACTORY_DEF * TeeFactory   FACTORY_NAME "GeometryFilter <UNFILTERED> Transformer Output Nuker"   INPUT FEATURE_TYPE GeometryFilter_<UNFILTERED>
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
